# Docker 開発環境 (docker-compose.yml) 用 環境変数テンプレート
#
# 使い方:
#   1. このファイルを `.env.docker` にコピー (`.env.docker` は gitignore 対象)
#        cp .env.docker.example .env.docker
#   2. 認証を実際に通したい場合は Clerk の test キーを各自の値に差し替える
#        (下記 stub のままだとサインイン/サインアップは動作しない)
#   3. `make setup` で起動 → migrate → seed
#
# 注意:
#   - DATABASE_URL / DIRECT_URL の host は docker-compose の `db` サービス名。
#     ホストから直接 psql する場合は localhost:5432 を使う (compose が公開)。
#   - 本番 Neon とは分離した使い捨て DB。秘密情報は入れないこと。

# === データベース (compose の db サービス) ===
DATABASE_URL=postgresql://dev:dev@db:5432/multivendor_dev
DIRECT_URL=postgresql://dev:dev@db:5432/multivendor_dev

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Clerk (認証を通すには test キーへ差し替え) ===
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_ci-stub
CLERK_SECRET_KEY=sk_test_ci-stub
WEBHOOK_SECRET=whsec_ci-stub
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/

# === Stripe (決済を試す場合は test キーへ差し替え) ===
STRIPE_SECRET_KEY=sk_test_ci-stub
STRIPE_WEBHOOK_SECRET=whsec_ci-stub
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_ci-stub

# === PayPal (決済を試す場合は sandbox キーへ差し替え) ===
NEXT_PUBLIC_PAYPAL_CLIENT_ID=ci-stub
PAYPAL_SECRET=ci-stub
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_ID=ci-stub

# === Cloudinary (画像アップロードを試す場合は実値へ差し替え) ===
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=ci-stub
NEXT_PUBLIC_CLOUDINARY_PRESET_NAME=ci-stub

# === IpInfo (地域判定。任意) ===
IPINFO_TOKEN=

# === SonarQube (ローカル静的解析。make sonar-scan で使用) ===
#   1. make sonar-up で起動 → http://localhost:9000 (admin/admin) でログイン
#   2. My Account → Security でトークンを発行し SONAR_TOKEN に設定
#   SONAR_HOST_URL は docker-compose.sonar.yml の scanner コンテナが Docker 内部ネットワーク
#   経由で SonarQube へ到達するアドレス（make sonar-scan で参照される）。
#   デフォルトの http://sonarqube:9000 は docker-compose.sonar.yml::scanner の
#   ${SONAR_HOST_URL:-http://sonarqube:9000} で補完されるため、変更不要なら空欄のままでよい。
#   ブラウザから UI を開く場合は http://localhost:9000 を使う（外部公開ポートは 9000）。
SONAR_TOKEN=
SONAR_HOST_URL=
