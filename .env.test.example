# Integration テスト用 環境変数テンプレート
#
# 使い方:
#   1. このファイルを `.env.test` にコピー (`.env.test` は gitignore 対象)
#   2. 下記のうちどちらかを選択:
#      - testcontainers モード (推奨): DATABASE_URL を空のままにする →
#        `tests/integration/setup/container.ts` の globalSetup が Postgres コンテナを自動起動
#      - docker-compose モード: 下記の DATABASE_URL を有効化し
#        `docker compose -f docker-compose.test.yml up -d` で起動済みのサービスへ接続
#
# 関連: docs/architecture/decisions/004-integration-test-db-strategy.md
#       docker-compose.test.yml
#       tests/integration/setup/container.ts

# === testcontainers モード (デフォルト) ===
# DATABASE_URL=

# === docker-compose.test.yml モード ===
# 外部 DB を使う場合は以下 2 つを必ず有効化する (どちらか欠けると globalSetup が throw):
#   1. INTEGRATION_DB_ALLOW_EXTERNAL=1  ... 実 DB へ migrate/TRUNCATE するための明示オプトイン
#   2. DB 名に "test" / "integration" を含むこと (dev/prod 誤接続の防止ガード)
# DIRECT_URL は未設定なら DATABASE_URL を流用する (schema の directUrl 解決用)。
# INTEGRATION_DB_ALLOW_EXTERNAL=1
# DATABASE_URL=postgresql://test:test@localhost:55432/integration_test

# Clerk / Stripe 等の外部サービスは Integration テストでもモック化するため、
# CI の .github/workflows/ci.yml と同じ stub 値を使う:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_ci-stub
CLERK_SECRET_KEY=sk_test_ci-stub
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
WEBHOOK_SECRET=whsec_ci-stub
STRIPE_SECRET_KEY=sk_test_ci-stub
STRIPE_WEBHOOK_SECRET=whsec_ci-stub
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_ci-stub
NEXT_PUBLIC_PAYPAL_CLIENT_ID=ci-stub
PAYPAL_SECRET=ci-stub
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=ci-stub
NEXT_PUBLIC_CLOUDINARY_PRESET_NAME=ci-stub
NEXT_PUBLIC_APP_URL=http://localhost:3000
